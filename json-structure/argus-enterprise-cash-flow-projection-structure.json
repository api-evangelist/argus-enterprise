{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/argus-enterprise/refs/heads/main/json-structure/argus-enterprise-cash-flow-projection-structure.json",
  "name": "CashFlowProjection",
  "description": "CashFlowProjection schema from ARGUS Enterprise API",
  "type": "object",
  "properties": {
    "propertyId": {
      "type": "string",
      "format": "uuid",
      "description": "Associated property identifier"
    },
    "startDate": {
      "type": "date",
      "description": "Projection start date"
    },
    "endDate": {
      "type": "date",
      "description": "Projection end date"
    },
    "frequency": {
      "type": "string",
      "enum": [
        "Monthly",
        "Quarterly",
        "Annual"
      ],
      "description": "Cash flow reporting frequency"
    },
    "currency": {
      "type": "string",
      "description": "Currency code (ISO 4217)"
    },
    "periods": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/CashFlowPeriod"
      },
      "description": "Individual cash flow periods"
    },
    "summary": {
      "$ref": "#/components/schemas/CashFlowSummary"
    }
  }
}